---
import { Markdown as RemoteMarkdown } from "astro-remote";
import { marked } from "marked";
import { gfmHeadingId } from "marked-gfm-heading-id";
import {
  replaceCmsEmbeds,
  forceHTMLBlocks,
} from "@millstreamwebsoftware/mws-astro/src/util.ts";
import Blockquote from "@millstreamwebsoftware/mws-astro/components/blockquote/blockquote.astro";
import Button from "@millstreamwebsoftware/mws-astro/components/button/button.astro";
import Icon from "@millstreamwebsoftware/mws-astro/shared/icon.astro";
import Mailbuild from "@millstreamwebsoftware/mws-astro/components/mailbuild/mailbuild.astro";
import Facebook from "@millstreamwebsoftware/mws-astro/components/facebook/facebook.astro";
import Social from "@millstreamwebsoftware/mws-astro/components/social/social.astro";
import Counter from "@millstreamwebsoftware/mws-astro/components/counter/counter.astro";
import AsideImage from "@millstreamwebsoftware/mws-astro/components/image/asideImage.astro";
import Player from "@millstreamwebsoftware/mws-astro/components/player/player.astro";
import Accordion from "@millstreamwebsoftware/mws-astro/components/accordion/accordion.astro";
import Navigation from "@millstreamwebsoftware/mws-astro/components/navigation/navigation.astro";

// Preprocess markdown to convert base64 encoded embeds to html, and force newlines after html elements
const content = forceHTMLBlocks(replaceCmsEmbeds(Astro.props.content));

var substitutions = {
  Accordion,
  blockquote: Blockquote,
  Icon,
  Newsletter: Mailbuild,
  Facebook,
  Social,
  'a[class*="button"]': Button,
  Player,
  Navigation,
  img: AsideImage,
  AsideImage,
  Counter,
};

var md: string | undefined;

if (!import.meta.env.SSR) {
  // marked.use(gfmHeadingId());
  // marked={{ extensions: [gfmHeadingId() as any] }}
  md = await marked.parse(content);
} else {
  // Get site specific custom snippets from src/snippets.ts
  const snippetGlob = import.meta.glob<Record<string, any>>("/src/snippets.ts");

  await snippetGlob?.["/src/snippets.ts"]?.()?.then(
    ({ snippets }) => Object.assign(substitutions, snippets),
    (error) => console.log(error),
  );
}
---

{
  md
    ? content && <Fragment set:html={md} />
    : content && (
        <RemoteMarkdown
          {content}
          sanitize={{ allowComponents: true }}
          components={substitutions}
        />
      )
}

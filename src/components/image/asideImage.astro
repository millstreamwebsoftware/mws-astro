---
import {
  default as Image,
  type Props as ImageProps,
} from "@shared/Image.astro";
import clsx from "clsx";
// import _preferences from "@data/preferences.json";
// const preferences = _preferences as unknown as Preferences;

import SimpleMarkdown from "@shared/SimpleMarkdown.astro";

export interface Props {
  image: ImageProps["image"];
  src?: string;
  width?: number;
  height?: number;
  alt?: string;
  title?: string;
  description?: string;
  fit?: "contain" | "cover";
  "data-fit"?: "contain" | "cover";
  "data-width"?: string;
  "data-height"?: string;
  align?: CssAlign;
  "data-align"?: "left" | "center" | "right";
  float?: "left" | "right";
  "data-float"?: "left" | "right";
  classes?: (string | string[])[];
  class?: string;
}

const {
  alt,
  classes = Astro.props.class,
  title,
  description,
  width,
  height,
  "data-width": maxWidth,
  "data-height": maxHeight,
  fit = Astro.props["data-fit"] ?? "contain",
  align = Astro.props["data-align"],
  float = Astro.props["data-float"],
} = Astro.props;

const image = Astro.props.src ?? Astro.props.image;
const _classes = clsx(classes).split(" ");

const style = {
  ...(maxWidth && { "--width": maxWidth }),
  ...(maxHeight && { "--height": maxHeight }),
  ...(align && { "--align": align }),
};
---

<figure
  class:list={["aside", ..._classes]}
  {title}
  data-fit={fit}
  data-float={float}
  {style}
>
  <Image
    {image}
    {alt}
    {fit}
    {width}
    {height}
    displayWidth={1}
    quality="mid"
    inheritScope={true}
  />
  {
    description && (
      <figcaption>
        <SimpleMarkdown content={description} />
      </figcaption>
    )
  }
</figure>

<style lang="scss">
  figure {
    margin: 2rem 0;
    position: relative;
    display: flex;
    flex-direction: column;

    @media screen and (min-width: 769px) {
      &[data-float] {
        clear: both;
        margin: 0;
      }
      &[data-float="left"] {
        float: left;
        margin-right: 2em;
      }
      &[data-float="right"] {
        float: right;
        margin-left: 2em;
      }
    }
    &[data-fit="cover"] {
      width: var(--width);
      height: var(--height);

      figcaption {
        position: absolute;
        bottom: 0;
        width: 100%;
        z-index: 1;

        padding: 1rem;
        background-color: rgb(
          from var(--figure-caption-background-color, white) r g b / 0.7
        );
        backdrop-filter: var(--figure-caption-background-filter, blur(2px));
      }
    }
    &[data-fit="contain"] {
      width: var(--width);
      height: var(--height);
    }
    &:first-child {
      margin-top: 0;
    }
    &:last-child {
      margin-bottom: 0;
    }
    > img {
      margin: 0;
      border-radius: var(--image-border-radius, var(--border-radius));
      object-position: var(--align, center);
    }
    figcaption {
      padding-top: 0.5rem;
    }
  }
</style>

<style lang="scss" is:global>
  /* Live editor */
  :is(.text-content, accordion) {
    > img {
      margin-bottom: 2rem;
      border-radius: var(--image-border-radius, var(--border-radius));
      object-fit: contain;
      object-position: attr(data-align type(*), var(--align, center));

      &[data-fit="cover"] {
        object-fit: cover;
        width: 100%;
        height: 100%;
      }

      @media screen and (min-width: 769px) {
        &[data-float] {
          clear: both;
          margin: 0;
          width: attr(data-width type(<length-percentage>), auto);
          height: attr(data-height type(<length-percentage>), auto);
        }
        &[data-float="left"] {
          float: left;
          margin-right: 2em;
        }
        &[data-float="right"] {
          float: right;
          margin-left: 2em;
        }
      }
    }
  }
</style>

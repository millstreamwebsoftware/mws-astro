---
import { preferences } from "@millstreamwebsoftware/mws-astro/shared/preferences.ts";
import Icon from "@millstreamwebsoftware/mws-astro/shared/icon.astro";

export interface Props {
  // align?: string;
  // "show-text"?: boolean;
  socials?: [{ icon?: string; text?: string; link: string }];
}

// const { align, "show-text": text } = Astro.props;

const socialItems = Astro.props.socials?.length
  ? Astro.props.socials
  : preferences.general.social;

function getIcon(link: string) {
  if (link.startsWith("tel:")) return "fa6-solid:square-phone";
  if (link.startsWith("mailto:")) return "fa6-solid:square-envelope";
  if (link.startsWith("sms:")) return "fa6-solid:comment-sms";
  if (link.startsWith("/")) return "fa6-solid:comment-dots";

  try {
    const hostname = new URL(link).hostname.replace(/^www\./, "");
    return (
      {
        "twitter.com": "fa6-brands:square-x-twitter",
        "x.com": "fa6-brands:square-x-twitter",
        "facebook.com": "fa6-brands:square-facebook",
        "instagram.com": "fa6-brands:square-instagram",
        "linkedin.com": "fa6-brands:linkedin",
        "wa.me": "fa6-brands:square-whatsapp",
        "youtube.com": "fa6-brands:square-youtube",
        "youtu.be": "fa6-brands:square-youtube",
        "vimeo.com": "fa6-brands:square-vimeo",
      }[hostname] || "fa6-solid:square-up-right"
    );
  } catch (e) {
    if (e instanceof TypeError) return undefined;
    throw e;
  }
}

function getSocialName(link: string) {
  if (link.startsWith("tel:")) return "Phone";
  if (link.startsWith("mailto:")) return "E-Mail";
  if (link.startsWith("sms:")) return "SMS";
  if (link.startsWith("/")) return "Web Contact";

  try {
    const hostname = new URL(link).hostname.replace(/^www\./, "");
    return (
      {
        "twitter.com": "X (Twitter)",
        "x.com": "X (Twitter)",
        "facebook.com": "Facebook",
        "instagram.com": "Instagram",
        "linkedin.com": "LinkedIn",
        "wa.me": "WhatsApp",
        "youtube.com": "Youtube",
        "youtu.be": "Youtube",
        "vimeo.com": "Vimeo",
      }[hostname] || hostname
    );
  } catch (e) {
    if (e instanceof TypeError) return undefined;
    throw e;
  }
}

const socials: Record<string, string>[] = socialItems.map((s: any) => ({
  icon: s.icon ?? getIcon(s.link),
  link: s.link,
  text: s.text,
  alt: getSocialName(s.link) ?? s.text ?? s.link,
}));
---

<div class:list={["social"]}>
  {
    socials.map(
      (s) =>
        !!s.link && (
          <a
            href={s.link}
            class="social-item"
            rel="noopener noreferrer"
            target="_blank"
            title={s.title ?? `${preferences.general.site_name} - ${s.alt}`}
          >
            {s.icon && <Icon name={s.icon} height={"1.8em"} />}
            {s.text && <span>{s.text}</span>}
          </a>
        ),
    )
  }
</div>

<style lang="scss">
  .social {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;

    align-items: center;
    padding: var(--header-item-padding);
    padding-top: 0;
    padding-bottom: 0;
    gap: 1em;
  }

  a {
    display: flex;
    color: inherit;
    font-size: inherit;
    width: 100%;
    height: 100%;
    align-items: center;
    text-decoration: none;

    span {
      margin: 0 0.5em;
      white-space: nowrap;
    }
  }

  .social-item {
    width: min-content;
  }

  .social-item:hover {
    color: rgb(var(--header-hover-background-color));
  }
</style>

<style lang="scss" is:global>
  navigation.mobile-nav .social {
    justify-content: center;
  }
</style>

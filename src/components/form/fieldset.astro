---
import { components } from "virtual:mws-astro/components";
import { BUILDMODE } from "astro:env/client";

const selfName = "form/fieldset";
export interface Props {
  legend: string;
  form_blocks: any[];
  key?: string;
}

const { legend, form_blocks, key } = Astro.props;
const Wrapper = BUILDMODE === "EDITOR" ? "editable-array-item" : Fragment;
---

<fieldset>
  <legend>{legend}</legend>
  {
    form_blocks.map((block: any, i: any) => {
      if (block._bookshop_name == selfName) {
        return <Astro.self {...block} key={String(i) + (key || "")} />;
      }
      const Component = components[block._bookshop_name];
      if (Component) {
        return (
          <Wrapper
            data-id={block._bookshop_name}
            data-component={block._bookshop_name}
          >
            <Component {...block} key={String(i) + (key || "")} />
          </Wrapper>
        );
      }
      return (
        <div class="missing-component">
          {`Component ${block._bookshop_name} could not be found!`}
        </div>
      );
    })
  }
</fieldset>

<style>
  fieldset {
    display: flex;
    flex-direction: column;
    gap: var(--text-gap);
    margin-top: 1.5rem;
    margin-bottom: 1rem;
    border-radius: var(--border-radius);
    border: var(--form-border);
  }

  legend {
    font-size: larger;
    color: rgb(var(--text-color));
  }
</style>
